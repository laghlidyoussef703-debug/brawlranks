# EnvironmentFile for the aggregation worker.
#
# Install to:  /etc/brawlranks-worker/aggregation.env
# Ownership:   root:brawlworker   Mode: 0640   (readable by the service user,
#              NOT world-readable). NEVER commit the real file or print it.
#
# The worker connects with the WRITER role + TLS using the SAME resolution as
# the app (lib/mysql `getWritePool`): WRITE_DB_* variables are used when set,
# otherwise it falls back to the legacy DB_* variables. On the droplet, point
# these at the DigitalOcean managed MySQL writer endpoint.

# --- Writer role (preferred: dedicated writer endpoint + TLS) ---------------
WRITE_DB_HOST=your-do-mysql-host.db.ondigitalocean.com
WRITE_DB_PORT=25060
WRITE_DB_NAME=brawlranks
WRITE_DB_USER=brawlranks_writer
WRITE_DB_SECRET=__set_real_writer_password_here__
# DigitalOcean managed MySQL uses a CA-signed cert; verification stays ON.
WRITE_DB_CA_PATH=/etc/brawlranks-worker/do-mysql-ca.crt
WRITE_DB_POOL_SIZE=2

# --- Legacy fallback (only if WRITE_DB_* is not used) -----------------------
# DB_HOST=your-do-mysql-host.db.ondigitalocean.com
# DB_PORT=25060
# DB_NAME=brawlranks
# DB_USER=brawlranks_writer
# BRAWL_DB_SECRET_V1=__set_real_password_here__

# --- Worker tuning (optional) -----------------------------------------------
# AGG_WORKER_MODE=drive          # the systemd unit already passes --drive
# AGG_WORKER_BATCH_SIZE=8        # brawlers per slice (engine-clamped to 1..50)
# AGG_WORKER_MAX_SLICES=100000   # driver safety cap
# AGG_WORKER_PAUSE_MS=200        # pause between driver slices
