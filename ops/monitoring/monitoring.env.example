# Phase 15 monitoring env (install to /etc/brawlranks-worker/monitoring.env, 0640 root:brawlworker).
# Same writer-role DB vars as the other workers:
WRITE_DB_HOST=your-do-mysql-host.db.ondigitalocean.com
WRITE_DB_PORT=25060
WRITE_DB_NAME=brawlranks
WRITE_DB_USER=brawlranks_writer
WRITE_DB_SECRET=__set_real_writer_password_here__
WRITE_DB_CA_PATH=/etc/brawlranks-worker/do-mysql-ca.crt
# Optional capacity limit + backup/restore evidence + threshold overrides:
# MON_DB_CAPACITY_LIMIT_BYTES=64424509440
# MON_BACKUP_AGE_SECONDS=...
# MON_RESTORE_TEST_AGE_SECONDS=...
