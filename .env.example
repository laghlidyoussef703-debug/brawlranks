# BrawlRanks — environment variable template.
# Copy to .env.local for local development. NEVER commit real values.
# See BRAWLRANKS_WEBSITE_SPEC.md Section 24.11 for the full inventory.

# Phase 6A — public frontend foundation. Both read/validated by lib/env.ts.
# NEXT_PUBLIC_SITE_URL is inlined into the client bundle at build time (the
# NEXT_PUBLIC_ prefix), so it must never hold a secret — it is only ever the
# site's own public origin. Must be a valid absolute http(s) URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# APP_ENV is server-only (no NEXT_PUBLIC_ prefix, never sent to the client
# bundle) and gates environment-aware indexation: only "production" allows
# search engines to index the site (lib/env.ts, app/layout.tsx). Must be
# exactly one of: development, staging, production.
APP_ENV=development

# Hostinger MySQL (production database) — server-only
# The code reads exactly these five names; nothing else takes precedence
# (no DATABASE_URL, no fallback to DB_PASSWORD, DB_PASSWORD_V2,
# MYSQL_PASSWORD_20260715, MYSQL_AUTH_20260715, MYSQL_AUTH_B64_20260715,
# or ENV_PROBE_20260715). See lib/mysql.ts.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
BRAWL_DB_SECRET_V1=

# Dedicated migration identity for Phase 6+ (preferred over application users).
# When MIGRATION_DB_HOST is set, NAME/USER/SECRET are all mandatory and the
# migration runner does not borrow credentials from DB_*.
# MIGRATION_DB_HOST=
# MIGRATION_DB_PORT=25060
# MIGRATION_DB_NAME=brawlranks
# MIGRATION_DB_USER=migration_admin
# MIGRATION_DB_SECRET=
# MIGRATION_DB_CA_PATH=/etc/brawlranks/ssl/ca-certificate.crt
# MIGRATION_DB_SSL=true
# MIGRATION_DB_SSL_REJECT_UNAUTHORIZED=true

# Role-aware DB pools (DATASET Phase 9) — server-only, OPTIONAL.
# Backward-compatible and INERT until deliberately populated: when these are
# unset, getReadPool()/getWritePool() return the same legacy pool as getPool(),
# so connection count and behavior are unchanged. Populate a role only when a
# separate read (Phase 12) or write (Phase 10) endpoint is being cut over.
# A role is activated by setting its *_HOST; then *_NAME/*_USER/*_SECRET are
# all required (a partial role config is refused). Port defaults to 3306.
# READ_DB_HOST=
# READ_DB_PORT=25060
# READ_DB_NAME=
# READ_DB_USER=app_read
# READ_DB_SECRET=
# READ_DB_POOL_SIZE=2
# TLS: provide a CA to verify the managed endpoint. rejectUnauthorized is on by
# default; only READ_DB_SSL_REJECT_UNAUTHORIZED=false disables it (discouraged).
# READ_DB_CA_PATH=/etc/brawlranks/ssl/ca-certificate.crt
# READ_DB_SSL=true
# READ_DB_SSL_REJECT_UNAUTHORIZED=true
#
# WRITE_DB_HOST=
# WRITE_DB_PORT=25060
# WRITE_DB_NAME=
# WRITE_DB_USER=ingest_write
# WRITE_DB_SECRET=
# WRITE_DB_POOL_SIZE=2
# WRITE_DB_CA_PATH=/etc/brawlranks/ssl/ca-certificate.crt
# WRITE_DB_SSL=true
# WRITE_DB_SSL_REJECT_UNAUTHORIZED=true

# Phase 8 incremental synchronization CLI — operator shell only. Never put
# production values in this file or commit them. SOURCE must be a SELECT-only
# identity; TARGET is the migration writer. Both endpoints require verified
# TLS. State is external to both schemas and written atomically.
# SOURCE_DB_HOST=
# SOURCE_DB_PORT=3306
# SOURCE_DB_NAME=
# SOURCE_DB_USER=migration_readonly
# SOURCE_DB_SECRET=
# SOURCE_DB_CA_PATH=/secure/path/source-ca.crt
# SOURCE_DB_SSL=true
# SOURCE_DB_SSL_REJECT_UNAUTHORIZED=true
# SOURCE_DB_POOL_SIZE=2
# TARGET_DB_HOST=
# TARGET_DB_PORT=25060
# TARGET_DB_NAME=
# TARGET_DB_USER=migration_writer
# TARGET_DB_SECRET=
# TARGET_DB_CA_PATH=/secure/path/target-ca.crt
# TARGET_DB_SSL=true
# TARGET_DB_SSL_REJECT_UNAUTHORIZED=true
# TARGET_DB_POOL_SIZE=2
# MIGRATION_SYNC_STATE_DIR=/var/lib/brawlranks-migration-sync

# Raw snapshot archive object storage (DATASET Phase 4) — server-only, OPTIONAL.
# S3-compatible (DigitalOcean Spaces). The archive cron route returns 503 until
# these are set. Credentials are never logged. All five are required together;
# a partial config is refused. Copy-only: the worker never deletes/nulls a
# payload. Enabling the archive timer is an explicit owner action.
# ARCHIVE_S3_ENDPOINT=https://fra1.digitaloceanspaces.com
# ARCHIVE_S3_REGION=fra1
# ARCHIVE_S3_BUCKET=brawlranks-raw-archive
# ARCHIVE_S3_ACCESS_KEY_ID=
# ARCHIVE_S3_SECRET_ACCESS_KEY=
# ARCHIVE_S3_FORCE_PATH_STYLE=true

# DigitalOcean fixed-IP proxy — server-only
DIGITALOCEAN_PROXY_URL=https://proxy.brawlranks.com
PROXY_SHARED_SECRET=

# Internal endpoint authentication (Hostinger cron -> app) — server-only
# Required as: Authorization: Bearer <INTERNAL_CRON_SECRET>
# Used by every /api/internal/cron/* and /api/internal/test/* route,
# including Phase 3's ranking-seed-refresh, player-discovery,
# player-crawl-batch, battle-log-crawl-batch, club-expansion, and
# ingestion-health.
INTERNAL_CRON_SECRET=
