# BrawlRanks — environment variable template.
# Copy to .env.local for local development. NEVER commit real values.
# See BRAWLRANKS_WEBSITE_SPEC.md Section 24.11 for the full inventory.

# Phase 6A — public frontend foundation. Both read/validated by lib/env.ts.
# NEXT_PUBLIC_SITE_URL is inlined into the client bundle at build time (the
# NEXT_PUBLIC_ prefix), so it must never hold a secret — it is only ever the
# site's own public origin. Must be a valid absolute http(s) URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# APP_ENV is server-only (no NEXT_PUBLIC_ prefix, never sent to the client
# bundle) and gates environment-aware indexation: only "production" allows
# search engines to index the site (lib/env.ts, app/layout.tsx). Must be
# exactly one of: development, staging, production.
APP_ENV=development

# Hostinger MySQL (production database) — server-only
# The code reads exactly these five names; nothing else takes precedence
# (no DATABASE_URL, no fallback to DB_PASSWORD, DB_PASSWORD_V2,
# MYSQL_PASSWORD_20260715, MYSQL_AUTH_20260715, MYSQL_AUTH_B64_20260715,
# or ENV_PROBE_20260715). See lib/mysql.ts.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
BRAWL_DB_SECRET_V1=

# DigitalOcean fixed-IP proxy — server-only
DIGITALOCEAN_PROXY_URL=https://proxy.brawlranks.com
PROXY_SHARED_SECRET=

# Internal endpoint authentication (Hostinger cron -> app) — server-only
# Required as: Authorization: Bearer <INTERNAL_CRON_SECRET>
# Used by every /api/internal/cron/* and /api/internal/test/* route,
# including Phase 3's ranking-seed-refresh, player-discovery,
# player-crawl-batch, battle-log-crawl-batch, club-expansion, and
# ingestion-health.
INTERNAL_CRON_SECRET=
