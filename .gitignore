# editor
.vscode/
.idea/

# database backups and dumps (DATASET Phase 2)
# A real dump contains the entire production dataset and must never enter
# Git. Store backups outside this repository entirely — see
# docs/dataset/restore-runbook.md section 4. These patterns are a safety
# net, not the primary control.
*.sql.gz
*.sql.age
*.sql.gpg
*.dump
*.dump.gz
*-backup-*.sql
*.manifest.json
/backups/
/brawlranks-backups/
schema-inventory.json
restore-validation*.txt

# DATASET Phase 4 — generated raw-archive objects must never enter Git.
# The archive worker writes gzip'd payloads to object storage (or a local dir
# in tests/proofs); these are production data copies, not source.
*.json.gz
/archive-store/
/tmp-archive/
**/raw/v1/**
